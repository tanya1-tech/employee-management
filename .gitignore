# ============================================
# NODE.js DEPENDENCIES
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ============================================
# ENVIRONMENT VARIABLES (CRITICAL!)
# ============================================
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
*.env

# ============================================
# BUILD OUTPUTS
# ============================================
dist/
build/
out/
*.tsbuildinfo
*.turbo

# ============================================
# BACKEND SPECIFIC
# ============================================
backend/node_modules/
backend/package-lock.json
backend/.env
backend/.env.local
backend/dist/
backend/build/
backend/logs/
backend/*.log

# ============================================
# 🚨 ALL SCRIPTS WITH PASSWORDS & SENSITIVE DATA
# ============================================

# Ignore entire scripts folder
scripts/
**/scripts/

# All password-related scripts
**/scripts/*password*.js
**/scripts/*-password*.js
**/scripts/reset-*.js
**/scripts/update-*.js
**/scripts/change-*.js
**/scripts/create-*.js
**/scripts/set-*.js
**/scripts/fix-*.js
**/scripts/debug-*.js
**/scripts/test-*.js
**/scripts/find-*.js
**/scripts/link-*.js
**/scripts/cleanup-*.js
**/scripts/seed.js
**/scripts/insert-*.js
**/scripts/*-data.js
**/scripts/add-*.js
**/scripts/init-*.js
**/scripts/migrate-*.js
**/scripts/db-*.js

# All scripts in root
scripts/
*.js
!index.js
!server.js
!app.js

# But keep these example/template files
!**/scripts/*.example.js
!**/scripts/*.template.js
!**/scripts/*.sample.js

# ============================================
# DATABASE FILES & SCRIPTS
# ============================================

# Database files
*.db
*.sqlite
*.sqlite3
*.mongodb
*.dump
*.sql
backup-*.sql
database-backup-*

# MongoDB data directory
data/
db-data/
mongodb-data/
mongodb/
*.bson
*.json
*.js

# Database connection files (if they contain credentials)
**/db.config.js
**/database.config.js
**/mongoose.config.js
**/db.js
!**/db.js.example

